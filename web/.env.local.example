# Copy to .env.local — never commit .env.local

# Supabase (Project Settings > API)
# Project URL only — do NOT add /rest/v1/
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Optional — for `npm run apply-supabase-auth` (Management API, dashboard account token)
# SUPABASE_ACCESS_TOKEN=sbp_...

# Public site URL (no trailing slash) — Netlify production URL or http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe (Developers > API keys — start with test keys)
# Webhook endpoint (Netlify prod): https://YOUR_NETLIFY_DOMAIN/api/webhooks/stripe
# Dashboard signing secret must match STRIPE_WEBHOOK_SECRET
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_signing_secret

# Optional — default aud
STRIPE_CURRENCY=aud

# Local datetime fields (admin “New session”) are interpreted in this offset (AEST +10, AEDT +11)
BOOKING_TZ_OFFSET=+10:00

# Display session times to players (IANA zone, DST-aware). Defaults to Australia/Sydney.
NEXT_PUBLIC_BOOKING_TIMEZONE=Australia/Sydney

# WhatsApp Cloud API (Meta Developer App > WhatsApp)
# 1) Meta App Dashboard → WhatsApp → Configuration → Webhook callback URL:
#    https://YOUR_NETLIFY_DOMAIN/api/webhooks/whatsapp
# 2) Subscribe fields: messages (and contacts if available)
# 3) Paste the same VERIFY_TOKEN here and in Meta as the verify token
# Webhook URL (local): use a tunnel (e.g. ngrok) to the same path for dev
WHATSAPP_VERIFY_TOKEN=choose-a-random-string
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Optional UUID — if set, BOOK/STATUS use this play_session when open; else earliest open session
WHATSAPP_DEFAULT_PLAY_SESSION_ID=

# After DB migrations: run `web/supabase/ops/verify_whatsapp_schema.sql` in Supabase SQL Editor
# to confirm 002 + 003 objects exist on the linked project.

# Optional — waitlist promotion email (Resend: https://resend.com)
# Verify your sending domain in Resend before production use.
# RESEND_API_KEY=re_...
# BOOKING_EMAIL_FROM=ShuttleBook <bookings@yourdomain.com>
